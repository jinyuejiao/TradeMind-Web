<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <script src="../../assets/js/env-config.js"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>TradeMind е•Ҷиҙёжҷәи„‘ - дә§е“Ғдёӯеҝғ</title>
    <link rel="icon" href="../../favicon.ico" type="image/x-icon">
    <link rel="shortcut icon" href="../../favicon.ico" type="image/x-icon">

    <style>
        body {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* жҠҘиЎЁзҫҺеҢ– CSS */
        .bar-item-slim {
            width: 14px;
            border-radius: 20px 20px 2px 2px;
            transition: height 0.8s cubic-bezier(0.17, 0.67, 0.83, 0.67);
            background: linear-gradient(180deg, #14B8A6 0%, #0D9488 100%);
        }

        .chart-container-svg {
            width: 180px;
            height: 180px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .donut-text-box {
            position: absolute;
            text-align: center;
            z-index: 10;
        }

        .axis-text {
            font-size: 10px;
            color: #94A3B8;
            font-family: font-mono, sans-serif;
            font-weight: bold;
            margin-top: 10px;
        }

        /* еј№зӘ—еҸҠиЎЁеҚ•дё“з”?*/
        .sub-tab-btn {
            padding: 12px 24px;
            font-size: 13px;
            font-weight: 700;
            color: #94A3B8;
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
        }

            .sub-tab-btn.active {
                color: var(--brand-primary);
                border-bottom-color: var(--brand-primary);
            }

        /* й«ҳзә§й…ҚзҪ®жҠҪеұү */
        .advanced-drawer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
        }

            .advanced-drawer.open {
                max-height: 1000px;
                transition: max-height 0.4s ease-in;
            }

        /* е“Қеә”ејҸеҲ—иЎЁеұ•зӨәйҖ»иҫ‘ */
        @media (max-width: 768px) {
            #main-sidebar { position: fixed; inset-y: 0; left: 0; z-index: 50; transform: translateX(-100%); transition: transform 0.3s ease; }
            #main-sidebar.open { transform: translateX(0); }
            
            /* жүӢжңәз«Ҝйҡҗи—ҸйғЁеҲҶеҲ— */
            .col-hide-mobile { display: none !important; }
            .col-width-mobile { width: 70% !important; }
        }

        /* ж“ҚдҪңжҢүй’®ж ·ејҸ */
        .action-icon-btn {
            padding: 6px;
            border-radius: 8px;
            transition: all 0.2s;
            color: #94A3B8;
        }

        .action-icon-btn:hover {
            background-color: #F1F5F9;
            color: #14B8A6;
        }

        .action-icon-btn.delete:hover {
            color: #F43F5E;
            background-color: #FEF2F2;
        }
    </style>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="../CSS/common.css">
    <script>
        tailwind.config = {
            theme: { extend: { colors: { brand: { 50: '#F0FDFA', 100: '#CCFBF1', 500: '#14B8A6', 600: '#0D9488', 900: '#134E4A' }, risk: { high: '#F43F5E', medium: '#F59E0B', safe: '#10B981' } } },
            future: {
                disableColorOpacityUtilitiesByDefault: true,
                relativeContentPathsByDefault: true
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@latest"></script>
    <script src="../../assets/js/auth.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script>
        // йЎөйқўеҠ иҪҪж—¶еҲқе§ӢеҢ–е…¬е…ұ UI з»„д»¶
        document.addEventListener('DOMContentLoaded', function() {
            // жіЁе…Ҙе…¬е…ұ UI з»„д»¶
            if (window.injectCommonUI) {
                window.injectCommonUI();
            }
        });
    </script>

</head>
<body class="bg-slate-100 text-slate-600 font-sans h-screen w-full flex overflow-hidden">

    <!-- 1. дҫ§иҫ№еҜјиҲӘж ?-->
    <aside class="hidden md:flex w-64 bg-slate-900 border-r border-slate-800 flex-shrink-0 flex-col z-20 shadow-xl" id="main-sidebar">
        <!-- Logo еҢәеҹҹ -->
        <div class="h-16 flex items-center px-6 border-b border-slate-800">
            <div class="w-10 h-10 bg-[#14B8A6] rounded-xl flex items-center justify-center mr-3 text-white shadow-lg shadow-[#14B8A6]/20">
                <i class="ph ph-brain text-xl"></i>
            </div>
            <span class="text-white text-lg font-bold tracking-wider">TradeMind</span>
        </div>
        <nav class="flex-1 py-6 px-3 space-y-1">
            <button onclick="switchTab('dashboard')" class="nav-btn w-full flex items-center px-3 py-3 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all">
                <i class="ph ph-squares-four text-xl mr-3"></i> <span class="text-sm font-medium">е·ҘдҪңеҸ?/span>
            </button>
            <button onclick="switchTab('biz')" class="nav-btn w-full flex items-center px-3 py-3 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all">
                <i class="ph ph-chart-line-up text-xl mr-3"></i> <span class="text-sm font-medium">жҷәиғҪз»ҸиҗҘ</span>
            </button>
            <button onclick="switchTab('crm')" class="nav-btn w-full flex items-center px-3 py-3 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all">
                <i class="ph ph-users text-xl mr-3"></i> <span class="text-sm font-medium">е®ўжҲ· CRM</span>
            </button>
            <button onclick="switchTab('supply')" class="nav-btn w-full flex items-center px-3 py-3 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all active-nav bg-slate-800 text-brand-500">
                <i class="ph ph-flask text-xl mr-3"></i> <span class="text-sm font-medium">дә§е“Ғдёӯеҝғ</span>
            </button>
            <button onclick="switchTab('supplier')" class="nav-btn w-full flex items-center px-3 py-3 text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition-all">
                <i class="ph ph-warehouse text-xl mr-3"></i> <span class="text-sm font-medium">дҫӣеә”е•Ҷз®Ўзҗ?/span>
            </button>
        </nav>
        <!-- з”ЁжҲ·дҝЎжҒҜеҢәеҹҹ -->
        <div class="p-4 border-t border-slate-800 bg-slate-900 mt-auto flex items-center cursor-pointer transition-all hover:bg-slate-800" onclick="openSubscriptionModal()">
            <div class="w-10 h-10 rounded-full bg-slate-800 text-[#14B8A6] border-2 border-[#14B8A6] flex items-center justify-center text-xs font-bold font-mono" id="sidebar-user-avatar">AD</div>
            <div class="ml-3 text-left">
                <p class="text-xs font-bold text-slate-200" id="sidebar-user-name">з”ЁжҲ· (и§’иүІ)</p>
                <div class="flex items-center gap-1.5 mt-1">
                    <i class="ph ph-crown text-[#14B8A6] text-[10px]"></i>
                    <span class="text-[#14B8A6] text-[10px] font-bold">иҜ•з”ЁзүҲжң¬</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- 2. дё»е·ҘдҪңеҢә -->
    <main class="flex-1 flex flex-col min-w-0 relative h-full">
        <!-- Header -->
        <header class="hidden md:flex h-14 md:h-16 bg-white/90 backdrop-blur border-b border-slate-200 items-center justify-between px-4 md:px-8 sticky top-0 z-30 flex-shrink-0">
            <div class="md:hidden flex items-center"><div class="w-7 h-7 bg-brand-500 rounded flex items-center justify-center text-white mr-2"><i class="ph ph-brain text-lg"></i></div><span class="font-bold text-slate-800">е•Ҷиҙёжҷәи„‘</span></div>
            <div class="hidden md:flex items-center w-1/3 text-slate-400 group"><i class="ph ph-magnifying-glass text-lg group-focus-within:text-brand-600 transition"></i><input type="text" placeholder="жҗңзҙўжҠҘиЎЁгҖҒеҚ•жҚ®гҖҒAIжҢҮд»Ө..." class="bg-transparent border-none focus:outline-none text-slate-700 w-full ml-3 placeholder-slate-400 text-sm font-medium"></div>
            <div class="flex items-center space-x-3 md:space-x-5">
                <div class="hidden md:flex items-center px-3 py-1 bg-slate-100 border border-slate-200 rounded-full">
                    <span class="w-2 h-2 bg-brand-500 rounded-full mr-2 tech-pulse"></span>
                    <span class="text-xs font-bold text-slate-600 tracking-wide" id="page-title">дә§е“Ғдёӯеҝғ</span>
                </div>
                <button class="relative text-slate-400 hover:text-brand-600 transition"><i class="ph ph-bell text-xl"></i></button>
            </div>
        </header>

        <!-- еҶ…е®№еҢәеҹҹ -->
        <div id="content-area" class="flex-1 overflow-y-auto bg-slate-50 no-scrollbar pb-24 md:pb-0">

            <!-- ================= [4] дә§е“Ғдёӯеҝғ ================= -->
            <div id="view-supply" class="view-section w-full p-4 md:p-8 space-y-6 fade-in">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <h2 class="text-xl font-bold text-slate-800 uppercase tracking-tight">дә§е“Ғдёӯеҝғ</h2>
                    <div class="flex items-center gap-3 flex-wrap">
                        <!-- жҗңзҙўжЎ?-->
                        <div class="relative flex-1 max-w-xs">
                            <i class="ph ph-magnifying-glass absolute left-3 top-2.5 text-slate-400"></i>
                            <input type="text" id="inventorySearch" onkeyup="filterInventoryTable()" placeholder="еҝ«йҖҹжҗңзҙўеҗҚз§°жҲ– SKU..." class="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-xl text-xs focus:outline-none focus:border-brand-500 shadow-sm transition-all">
                        </div>
                        <!-- д»“еә“з®ЎзҗҶжҢүй’® -->
                        <button id="btn-warehouse-management" onclick="openWarehouseDrawer()" class="p-2.5 bg-slate-100 rounded-xl text-slate-600 hover:bg-slate-200 transition-colors flex items-center justify-center">
                            <i class="ph ph-buildings text-lg"></i>
                        </button>
                        <!-- з”ҹжҲҗиҝӣиҙ§еҚ•жҚ®жҢүй’® -->
                        <button id="btn-generate-restock" onclick="openPurchaseSuggestionModal()" class="bg-slate-800 text-white px-5 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2">
                            <i class="ph ph-receipt text-lg"></i> з”ҹжҲҗиҝӣиҙ§еҚ•жҚ®
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 gap-6">
                    <!-- дә§е“Ғеә“дё»иЎ?(е…ЁеұҸе®ҪеәҰ) -->
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                            <div class="px-6 py-4 border-b border-slate-50 flex flex-col md:flex-row justify-between items-center gap-4 bg-slate-50/30">
                                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest">зҺ°жңүдә§е“Ғеә?/h3>
                                <!-- ж–°еўһжҢүй’® -->
                                <div class="flex items-center">
                                    <button id="addProductBtn" onclick="openProductDetail('add')" class="bg-brand-500 text-white p-2 rounded-xl shadow-sm hover:bg-brand-600 transition-all">
                                        <i class="ph ph-plus text-lg"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="overflow-x-auto no-scrollbar">
                                <table class="w-full text-left border-collapse" id="existingProdTable">
                                    <thead class="bg-slate-50/50 text-[10px] text-slate-400 font-black uppercase tracking-tighter border-b border-slate-100">
                                        <tr>
                                            <th class="px-6 py-4 col-width-mobile">дә§е“ҒеҹәзЎҖдҝЎжҒҜ</th>
                                            <th class="px-6 py-4 col-hide-mobile">дё»й”ҖеҢәеҹҹ</th>
                                            <th class="px-6 py-4 text-right col-hide-mobile">й”Җе”®еқҮд»?/th>
                                            <th class="px-6 py-4 text-right">е®һж—¶еә“еӯҳ</th>
                                            <th class="px-6 py-4 text-right">з®ЎзҗҶ</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-xs divide-y divide-slate-50">
                                        <!-- дә§е“ҒиЎҢе°ҶйҖҡиҝҮJavaScriptеҠЁжҖҒз”ҹжҲ?-->
                                    </tbody>
                                </table>
                            </div>
                        </div>

                </div>
            </div>

            <!-- ================= [4] жүҖжңүеј№зӘ—жЁЎеқ?================= -->

            <!-- иҝӣиҙ§еҲ—иЎЁеј№зӘ— -->

            <!-- [жІүжөёејҸеј№зӘ—] дә§е“ҒиҜҰжғ…зј–иҫ‘ (ж ёеҝғй…ҚзҪ®) -->
            <div id="product-detail-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-0 md:p-8">
                <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeProductDetail()"></div>
                <div class="relative bg-white w-full max-w-4xl h-full max-h-[92vh] rounded-3xl shadow-2xl overflow-hidden flex flex-col fade-in modal-content-box text-left">
                    <!-- еј№зӘ—йЎөзңү -->
                    <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-white shrink-0">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 bg-brand-500 rounded-xl flex items-center justify-center text-white shadow-lg"><i class="ph ph-pencil-line text-xl"></i></div>
                            <div><h2 class="text-sm font-black text-slate-800" id="detail-title">дә§е“ҒиҜҰжғ…зј–иҫ‘</h2><p class="text-[10px] text-slate-400 font-mono tracking-widest mt-0.5" id="detail-sku">SKU: ---</p></div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button id="editProductBtn" onclick="toggleEditMode()" class="p-2 hover:bg-slate-100 rounded-full transition-colors hidden"><i class="ph ph-pencil-simple-line text-lg text-brand-600"></i></button>
                            <button onclick="closeProductDetail()" class="p-2 hover:bg-slate-100 rounded-full transition-colors"><i class="ph ph-x text-xl text-slate-400"></i></button>
                        </div>
                    </div>

                    <!-- иҜҰжғ…еҶ…е®№еҢ?-->
                    <div class="flex-1 overflow-y-auto p-6 md:p-10 no-scrollbar space-y-8">
                        <!-- 1. ж ёеҝғз»ҸиҗҘдҝЎжҒҜ -->
                        <section>
                            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2"><i class="ph ph-identification-card text-brand-500 text-lg"></i> ж ёеҝғз»ҸиҗҘдҝЎжҒҜ</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2 col-span-full"><label class="text-[11px] font-bold text-slate-500 ml-1">дә§е“Ғе…Ёз§°</label><input type="text" id="name" value="дёңеҢ—еӨ§жқҝ (еҺҹе‘із»Ҹе…ё)" class="form-input"></div>
                                <div class="space-y-2"><label class="text-[11px] font-bold text-slate-500 ml-1">SKU зј–з Ғ</label><input type="text" id="sku" value="DB-ICE-001" class="form-input font-mono"></div>
                                <div class="space-y-2"><label class="text-[11px] font-bold text-slate-500 ml-1">йў„и®ҫй”Җе”®д»· (USD)</label><input type="number" id="price" step="0.01" value="1.50" class="form-input font-mono font-bold text-brand-600"></div>

                                <!-- еҚ•дҪҚи§’иүІй…ҚзҪ®з»?-->
                                <div class="space-y-2">
                                    <label class="text-[11px] font-bold text-slate-500 ml-1">еҹәжң¬еҚ•дҪҚ (з»“з®—еә•ж•°)</label>
                                    <div class="flex gap-2">
                                        <input type="text" id="base_unit" value="ж ? class="form-input flex-1" placeholder="еҰӮпјҡж ?>
                                        <button onclick="openUnitModal()" class="px-3 bg-brand-50 text-brand-600 rounded-xl text-[10px] font-bold border border-brand-100 hover:bg-brand-100 transition-colors whitespace-nowrap">й…ҚзҪ®еҚ•дҪҚжҚўз®—</button>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <label class="text-[11px] font-bold text-slate-500 ml-1">й»ҳи®Өе…Ҙеә“еҚ•дҪҚ (йҮҮиҙӯ)</label>
                                    <select id="purchase_unit" class="form-input font-bold"><option>з®?(1з®?200ж ?</option><option>еҢ?(1еҢ?10ж ?</option><option>ж ?(еҹәжң¬еҚ•дҪҚ)</option></select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[11px] font-bold text-slate-500 ml-1">й»ҳи®Өй”Җе”®еҚ•дҪ?(еҮәеә“)</label>
                                    <select id="sales_unit" class="form-input font-bold text-brand-600"><option>еҢ?(1еҢ?10ж ?</option><option>ж ?(еҹәжң¬еҚ•дҪҚ)</option></select>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[11px] font-bold text-slate-500 ml-1">дҫӣеә”е•?/label>
                                    <select id="supplier_id" class="form-input font-bold"><option value="">иҜ·йҖүжӢ©дҫӣеә”е•?/option></select>
                                </div>
                            </div>
                        </section>

                        <!-- 2. дә§е“Ғй«ҳзә§дҝЎжҒҜ -->
                        <div class="pt-4 border-t border-slate-50 mt-6">
                            <button onclick="toggleAdvanced('prod')" class="flex items-center gap-1 text-[11px] font-bold text-slate-400 hover:text-slate-600 transition">й«ҳзә§й…ҚзҪ®дҝЎжҒҜ <i id="icon-prod" class="ph ph-caret-down"></i></button>
                            <div id="drawer-prod" class="advanced-drawer mt-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2"><label class="text-[11px] font-bold text-slate-500 ml-1">дә§е“ҒеҲҶзұ»</label><select id="category" class="form-input"><option>жҲ·еӨ–з…§жҳҺ</option><option>е®¶еұ…иЈ…йҘ°</option></select></div>
                                <div class="space-y-2"><label class="text-[11px] font-bold text-slate-500 ml-1">йў„иӯҰеә“еӯҳ</label><input type="number" id="warning_stock" value="100" class="form-input"></div>
                                <div class="space-y-2 md:col-span-2"><label class="text-[11px] font-bold text-slate-500 ml-1">дә§е“ҒиҜҰз»ҶжҸҸиҝ°</label><textarea id="description" class="form-input h-24 no-scrollbar">AI иҮӘеҠЁжҸҗеҸ–з”ҹжҲҗзҡ„жҸҸиҝ°пјҡе…·еӨҮе…үж„ҹиҮӘйҖӮеә”и°ғиҠӮеҠҹиғҪ...</textarea></div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- еј№зӘ—еә•йғЁж“ҚдҪң -->
                    <div id="productActions" class="p-6 border-t border-slate-100 bg-white flex flex-col md:flex-row justify-between items-center gap-4 shrink-0 hidden">
                        <button onclick="closeProductDetail()" class="flex-1 md:flex-none px-8 py-3 rounded-2xl border border-slate-200 text-xs font-bold text-slate-500 hover:bg-slate-50 transition">еҸ–ж¶Ҳиҝ”еӣһ</button>
                        <button onclick="saveProduct()" class="flex-[2] md:flex-none px-10 py-3 rounded-2xl bg-brand-600 text-white text-xs font-black shadow-xl shadow-brand-500/30 hover:bg-brand-700 transition active:scale-95">дҝқеӯҳдҝ®ж”№еҶ…е®№</button>
                    </div>
                </div>
            </div>



            <!-- иҝӣиҙ§е»әи®®еј№зӘ— -->
            <div id="purchase-suggestion-modal" class="hidden fixed inset-0 z-[120] flex items-center justify-center p-0 md:p-8">
                <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closePurchaseSuggestionModal()"></div>
                <div class="relative bg-white w-full max-w-4xl h-full max-sm:h-full max-sm:rounded-none md:h-auto md:max-h-[90vh] rounded-none md:rounded-[3rem] shadow-2xl overflow-hidden flex flex-col fade-in">
                    <div class="px-8 py-5 border-b border-slate-100 flex justify-between items-center bg-white shrink-0">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center text-white shadow-lg">
                                <i class="ph ph-receipt text-xl"></i>
                            </div>
                            <div>
                                <h2 class="text-sm font-black text-slate-800 tracking-widest">иҝӣиҙ§е»әи®®</h2>
                                <p class="text-[10px] text-slate-400 font-mono tracking-widest mt-0.5">Purchase Suggestion</p>
                            </div>
                        </div>
                        <button onclick="closePurchaseSuggestionModal()" class="p-2 hover:bg-slate-100 rounded-full transition-colors">
                            <i class="ph ph-x text-xl text-slate-400"></i>
                        </button>
                    </div>

                    <div class="flex-1 overflow-y-auto p-6 md:p-10 no-scrollbar space-y-8" id="purchase-suggestion-content">
                        <!-- еҶ…е®№е°ҶйҖҡиҝҮ JavaScript еҠЁжҖҒз”ҹжҲ?-->
                        <div class="text-center py-12">
                            <i class="ph ph-hourglass-simple text-4xl text-slate-300 mb-4"></i>
                            <p class="text-sm text-slate-400">жӯЈеңЁз”ҹжҲҗиҝӣиҙ§е»әи®®...</p>
                        </div>
                    </div>

                    <div class="p-6 border-t border-slate-100 bg-white flex flex-col md:flex-row justify-between items-center gap-4 shrink-0 max-sm:fixed max-sm:bottom-0 max-sm:left-0 max-sm:right-0 max-sm:bg-white/90 max-sm:backdrop-blur">
                        <p class="text-[10px] text-slate-400 italic">еҹәдәҺеҪ“еүҚеә“еӯҳйў„иӯҰеҖјиҮӘеҠЁи®Ўз®?/p>
                        <div class="flex gap-3 w-full md:w-auto">
                            <button onclick="closePurchaseSuggestionModal()" class="flex-1 md:flex-none px-8 py-3 rounded-2xl border border-slate-200 text-xs font-bold text-slate-500 hover:bg-slate-50 transition">
                                еҸ–ж¶Ҳиҝ”еӣһ
                            </button>
                            <button onclick="savePurchaseOrder()" class="flex-[2] md:flex-none px-12 py-3 rounded-2xl bg-brand-600 text-white text-xs font-black shadow-xl shadow-brand-500/30 hover:bg-brand-700 transition active:scale-95 flex items-center justify-center gap-2">
                                <i class="ph ph-floppy-disk-back"></i> дҝқеӯҳиҝӣиҙ§еҚ?                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- д»“еә“з®ЎзҗҶжҠҪеұү -->
            <div id="warehouse-drawer" class="hidden fixed right-0 inset-y-0 z-[130] w-full sm:w-96 bg-white shadow-2xl overflow-hidden flex flex-col">
                <div class="p-6 border-b border-slate-100 flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-slate-900 rounded-xl flex items-center justify-center text-white shadow-lg">
                            <i class="ph ph-buildings text-xl"></i>
                        </div>
                        <div>
                            <h2 class="text-sm font-black text-slate-800 tracking-widest">д»“еә“з®ЎзҗҶ</h2>
                            <p class="text-[10px] text-slate-400 font-mono tracking-widest mt-0.5">Warehouse Management</p>
                        </div>
                    </div>
                    <button onclick="closeWarehouseDrawer()" class="p-2 hover:bg-slate-100 rounded-full transition-colors">
                        <i class="ph ph-x text-xl text-slate-400"></i>
                    </button>
                </div>

                <div class="flex-1 overflow-y-auto p-6 space-y-6">
                    <!-- ж–°еўһд»“еә“ -->
                    <div class="bg-slate-50 rounded-2xl p-4">
                        <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">ж–°еўһд»“еә“</h3>
                        <div class="space-y-3">
                            <div>
                                <label class="text-[9px] font-black text-slate-400 uppercase block mb-1">д»“еә“еҗҚз§°</label>
                                <input type="text" id="new-warehouse-name" class="w-full px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs focus:outline-none focus:border-brand-500 shadow-sm transition-all" placeholder="иҜ·иҫ“е…Ҙд»“еә“еҗҚз§?>
                            </div>
                            <div>
                                <label class="text-[9px] font-black text-slate-400 uppercase block mb-1">дҪҚзҪ®</label>
                                <input type="text" id="new-warehouse-location" class="w-full px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs focus:outline-none focus:border-brand-500 shadow-sm transition-all" placeholder="иҜ·иҫ“е…Ҙд»“еә“дҪҚзҪ?>
                            </div>
                            <button onclick="saveWarehouse()" class="w-full py-2.5 bg-brand-500 text-white text-xs font-bold rounded-xl hover:bg-brand-600 transition-colors">
                                дҝқеӯҳд»“еә“
                            </button>
                        </div>
                    </div>

                    <!-- д»“еә“еҲ—иЎЁ -->
                    <div>
                        <h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">зҺ°жңүд»“еә“</h3>
                        <div class="space-y-3" id="warehouse-list">
                            <!-- д»“еә“еҲ—иЎЁе°ҶйҖҡиҝҮJavaScriptеҠЁжҖҒз”ҹжҲ?-->
                        </div>
                    </div>
                </div>
            </div>

            <!-- еҲ йҷӨзЎ®и®Өеј№зӘ— -->
            <div id="delete-confirm-modal" class="hidden fixed inset-0 z-[110] flex items-center justify-center p-4">
                <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeDeleteConfirm()"></div>
                <div class="relative bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden fade-in">
                    <div class="px-6 py-5 border-b border-slate-100 font-bold text-slate-800 flex justify-between items-center bg-slate-50/50">
                        <span>зЎ®и®ӨеҲ йҷӨ</span>
                        <i class="ph ph-x cursor-pointer text-slate-400" onclick="closeDeleteConfirm()"></i>
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="text-center">
                            <i class="ph ph-warning-circle text-4xl text-risk-high mb-4"></i>
                            <p class="text-sm font-bold text-slate-800" id="delete-confirm-message">зЎ®е®ҡеҲ йҷӨдә§е“Ғ [name] еҗ—пјҹ</p>
                            <p class="text-[11px] text-slate-400 mt-2">жӯӨж“ҚдҪңдёҚеҸҜж’Өй”Җ</p>
                        </div>
                    </div>
                    <div class="p-4 border-t border-slate-50 bg-slate-50/50 flex gap-4">
                        <button onclick="closeDeleteConfirm()" class="flex-1 py-3 rounded-xl border border-slate-200 text-xs font-bold text-slate-400 hover:bg-slate-50 transition">еҸ–ж¶Ҳ</button>
                        <button onclick="confirmDelete()" class="flex-1 py-3 rounded-xl bg-risk-high text-white text-xs font-bold shadow-lg active:scale-95 transition">еҲ йҷӨ</button>
                    </div>
                </div>
            </div>

            <!-- JavaScript д»Јз Ғ -->
            <script>
                // е…ЁеұҖеҸҳйҮҸ
                let allProducts = [];
                let currentProductId = null;
                let currentProductUnits = [];
                let currentDeleteProductId = null;
                let currentDeleteWarehouseId = null;
                let isEditMode = false;

                // еӨҡеҚ•дҪҚжҚўз®—з®—жі?                function formatStock(stock, baseUnit, conversions) {
                    if (!conversions || conversions.length === 0) return `${stock} ${baseUnit || 'Pcs'}`;
                    // жҢүжҜ”дҫӢд»ҺеӨ§еҲ°е°ҸжҺ’еә?                    const sorted = conversions.sort((a, b) => b.ratio - a.ratio);
                    let remaining = stock;
                    let result = "";
                    sorted.forEach(c => {
                        const count = Math.floor(remaining / c.ratio);
                        if (count > 0) {
                            result += `${count}${c.unitName}`;
                            remaining %= c.ratio;
                        }
                    });
                    if (remaining > 0 || result === "") result += `${remaining}${baseUnit || 'Pcs'}`;
                    return result;
                }

                // йЎөйқўеҠ иҪҪж—¶еҲқе§ӢеҢ–
                document.addEventListener('DOMContentLoaded', function() {
                    // жЈҖжҹҘи®ӨиҜҒзҠ¶жҖ?                    if (window.checkAuth) {
                        console.log('и°ғз”Ёе…ЁеұҖcheckAuthеҮҪж•°жЈҖжҹҘи®ӨиҜҒзҠ¶жҖ?);
                        if (!window.checkAuth()) {
                            return;
                        }
                    } else {
                        console.log('е…ЁеұҖcheckAuthеҮҪж•°дёҚеӯҳеңЁпјҢжЈҖжҹҘжң¬ең°еӯҳеӮЁдёӯзҡ„token');
                        const token = localStorage.getItem('token');
                        if (!token) {
                            console.log('TokenдёҚеӯҳеңЁпјҢи·іиҪ¬еҲ°зҷ»еҪ•йЎөйқ?);
                            localStorage.clear();
                            window.location.href = '../../login.html';
                            return;
                        }
                    }
                    
                    // еҗҢжӯҘз”ЁжҲ·дёҠдёӢж–ҮдҝЎжҒ?                    if (window.syncUserContext) {
                        window.syncUserContext();
                    }
                    
                    loadProducts();
                });

                // еҠ иҪҪдә§е“ҒеҲ—иЎЁ
                async function loadProducts() {
                    try {
                        // и°ғз”ЁеҗҺз«ҜжҺҘеҸЈпјҢдёҚйңҖиҰҒдј йҖ’X-Tenant-IdпјҢеӣ дёәеҗҺз«Ҝдјҡд»ҺUserContextдёӯиҺ·еҸ?                        const response = await window.wrappedFetch('/api/v1/rd/products', {
                            method: 'GET'
                        });
                        
                        // жЈҖжҹҘе“Қеә”зҠ¶жҖҒз Ғ
                        if (response.status === 401) {
                            showNotification("зҷ»еҪ•иҝҮжңҹпјҢиҜ·йҮҚж–°зҷ»еҪ•", "error");
                            // и·іиҪ¬еҲ°зҷ»еҪ•йЎөйқ?                            window.location.href = '../../login.html';
                            return;
                        } else if (response.status === 500) {
                            showNotification("жңҚеҠЎеҷЁй…ҚзҪ®й”ҷиҜ?, "error");
                            return;
                        }
                        
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        
                        const data = await response.json();
                        
                        if (data.success) {
                            allProducts = data.data;
                            renderProductTable(allProducts);
                        } else {
                            console.error('еҠ иҪҪдә§е“ҒеҲ—иЎЁеӨұиҙҘ:', data.message);
                            showNotification('еҠ иҪҪеӨұиҙҘ: ' + data.message);
                        }
                    } catch (error) {
                        console.error('еҠ иҪҪдә§е“ҒеҲ—иЎЁејӮеёё:', error);
                        showNotification('еҠ иҪҪеӨұиҙҘ: ' + error.message);
                    }
                }
                
                // з”ҹжҲҗиҝӣиҙ§еҲ—иЎЁ
                
                // жёІжҹ“иҝӣиҙ§еҲ—иЎЁ
                
                // е…ій—ӯиҝӣиҙ§еҲ—иЎЁеј№зӘ—

                // жёІжҹ“дә§е“ҒиЎЁж ј
                function renderProductTable(products) {
                    const tableBody = document.querySelector('#existingProdTable tbody');
                    tableBody.innerHTML = '';

                    products.forEach(product => {
                        const row = document.createElement('tr');
                        row.className = 'product-row hover:bg-slate-50 transition-all cursor-pointer group';
                        row.onclick = () => openProductDetail('edit', product.productId);

                        // и®Ўз®—еә“еӯҳйў„иӯҰзҠ¶жҖ?                        const isWarning = product.stock <= (product.warning_stock || 0);
                        const stockColorClass = isWarning ? 'text-risk-high' : 'text-slate-900';
                        const progressColorClass = isWarning ? 'bg-risk-high' : 'bg-brand-500';
                        
                        // и®Ўз®—еә“еӯҳиҝӣеәҰзҷҫеҲҶжҜ”пјҲеҒҮи®ҫжңҖеӨ§еә“еӯҳдёә 2000пј?                        const maxStock = 2000;
                        const stockPercentage = Math.min((product.stock / maxStock) * 100, 100);

                        // ж јејҸеҢ–еӨҡеҚ•дҪҚеә“еӯҳ
                        const stockDisplay = formatStock(product.stock, product.base_unit || 'Pcs', product.unitConversions);

                        row.innerHTML = `
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center text-slate-400 group-hover:bg-brand-50 group-hover:text-brand-500 transition-colors">
                                        <i class="ph ph-lightbulb text-xl"></i>
                                    </div>
                                    <div>
                                        <p class="font-bold text-slate-800 product-name-cell">${product.name}</p>
                                        <p class="text-[10px] text-slate-400 font-mono product-sku-cell uppercase">SKU: ${product.sku}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 col-hide-mobile">
                                <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded-full font-bold">${product.region || 'жңӘи®ҫзҪ?}</span>
                            </td>
                            <td class="px-6 py-4 text-right font-mono font-bold text-slate-500 col-hide-mobile">
                                $${product.price}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <p class="font-mono font-bold ${stockColorClass} tracking-tighter">${stockDisplay}</p>
                                <div class="w-16 h-1 bg-slate-100 rounded-full mt-1.5 ml-auto overflow-hidden md:block hidden">
                                    <div class="w-[${stockPercentage}%] ${progressColorClass} h-full"></div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <div class="flex justify-end gap-1">
                                    <button onclick="openProductDetail('edit', ${product.productId})" title="зј–иҫ‘" class="action-icon-btn">
                                        <i class="ph ph-pencil-simple-line text-lg"></i>
                                    </button>
                                    <button onclick="confirmDeleteProduct(${product.productId}, '${product.name}')" title="еҲ йҷӨ" class="action-icon-btn delete">
                                        <i class="ph ph-trash text-lg"></i>
                                    </button>
                                </div>
                            </td>
                        `;

                        tableBody.appendChild(row);
                    });
                }

                // йҳІжҠ–еҮҪж•°
                function debounce(func, wait) {
                    let timeout;
                    return function executedFunction(...args) {
                        const later = () => {
                            clearTimeout(timeout);
                            func(...args);
                        };
                        clearTimeout(timeout);
                        timeout = setTimeout(later, wait);
                    };
                }

                // жҗңзҙўжЎҶжЁЎзіҠжЈҖзҙўпјҲж”№дёәеҗҺз«Ҝжҗңзҙўпј?                const filterInventoryTable = debounce(function() {
                    const searchInput = document.getElementById('inventorySearch');
                    const searchTerm = searchInput.value.trim();
                    
                    if (searchTerm.length === 0) {
                        // еҰӮжһңжҗңзҙўиҜҚдёәз©әпјҢеҠ иҪҪжүҖжңүдә§е“?                        loadProducts();
                        return;
                    }
                    
                    // и°ғз”ЁеҗҺз«ҜжҗңзҙўжҺҘеҸЈ
                    window.wrappedFetch(`/api/v1/rd/products?search=${encodeURIComponent(searchTerm)}`, {
                        method: 'GET'
                    })
                    .then(response => {
                        if (!response.ok) {
                            // еҗҺз«ҜжңҚеҠЎдёҚеҸҜз”ЁпјҢдҪҝз”ЁеүҚз«ҜиҝҮж»Ө
                            console.log('еҗҺз«ҜжҗңзҙўжңҚеҠЎдёҚеҸҜз”ЁпјҢдҪҝз”ЁеүҚз«ҜиҝҮж»Ө');
                            frontendFilter(searchTerm);
                            throw new Error('Backend search service unavailable');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            const filteredProducts = data.data;
                            renderProductTable(filteredProducts);
                        } else {
                            console.error('жҗңзҙўдә§е“ҒеӨұиҙҘ:', data.message);
                            // дҪҝз”ЁеүҚз«ҜиҝҮж»Ө
                            frontendFilter(searchTerm);
                        }
                    })
                    .catch(error => {
                        console.log('дҪҝз”ЁеүҚз«ҜиҝҮж»Ө');
                        // дҪҝз”ЁеүҚз«ҜиҝҮж»Ө
                        frontendFilter(searchTerm);
                    });
                }, 300);

                // еүҚз«ҜиҝҮж»ӨпјҲеӨҮз”Ёпјү
                function frontendFilter(filter) {
                    const table = document.getElementById('existingProdTable');
                    const tr = table.getElementsByTagName('tr');
                    const filterUpper = filter.toUpperCase();

                    // д»Һз¬¬дәҢиЎҢејҖе§ӢпјҲи·іиҝҮиЎЁеӨҙпј?                    for (let i = 1; i < tr.length; i++) {
                        const nameCell = tr[i].querySelector('.product-name-cell');
                        const skuCell = tr[i].querySelector('.product-sku-cell');
                        if (nameCell && skuCell) {
                            const nameText = nameCell.textContent || nameCell.innerText;
                            const skuText = skuCell.textContent || skuCell.innerText;
                            if (nameText.toUpperCase().indexOf(filterUpper) > -1 || skuText.toUpperCase().indexOf(filterUpper) > -1) {
                                tr[i].style.display = '';
                            } else {
                                tr[i].style.display = 'none';
                            }
                        }
                    }
                }

                // еҠ иҪҪдҫӣеә”е•ҶеҲ—иЎ?                async function loadSuppliers() {
                    try {
                        const response = await window.wrappedFetch('/api/v1/supp/suppliers', {
                            method: 'GET'
                        });
                        
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        
                        const data = await response.json();
                        if (data.success) {
                            const suppliers = data.data;
                            const supplierSelect = document.getElementById('supplier_id');
                            supplierSelect.innerHTML = '<option value="">дёҚе…іиҒ”еӣәе®ҡдҫӣеә”е•Ҷ</option>';
                            
                            suppliers.forEach(supplier => {
                                const option = document.createElement('option');
                                option.value = supplier.supplierId;
                                option.textContent = supplier.name;
                                supplierSelect.appendChild(option);
                            });
                        }
                    } catch (error) {
                        console.error('еҠ иҪҪдҫӣеә”е•ҶеҲ—иЎЁеӨұиҙ?', error);
                    }
                }

                // жү“ејҖдә§е“ҒиҜҰжғ…
                async function openProductDetail(mode, productId) {
                    currentProductId = productId;
                    isEditMode = mode === 'add'; // ж–°еўһжЁЎејҸй»ҳи®ӨжҳҜзј–иҫ‘жЁЎеј?                    
                    // жҳҫзӨәжЁЎжҖҒжЎҶ
                    document.getElementById('product-detail-modal').classList.remove('hidden');
                    
                    // еҠ иҪҪдҫӣеә”е•ҶеҲ—иЎ?                    await loadSuppliers();
                    
                    if (mode === 'add') {
                        // ж–°еўһжЁЎејҸ
                        document.getElementById('detail-title').textContent = `ж–°еўһдә§е“Ғ`;
                        document.getElementById('detail-sku').textContent = `SKU: иҮӘеҠЁз”ҹжҲҗ`;
                        
                        // жё…з©әиЎЁеҚ•жүҖжңүеӯ—ж®?                        const formInputs = document.querySelectorAll('.form-input');
                        formInputs.forEach(input => {
                            if (input.type === 'text' || input.type === 'number' || input.tagName === 'TEXTAREA') {
                                input.value = '';
                            } else if (input.tagName === 'SELECT') {
                                input.selectedIndex = 0;
                            }
                        });
                        
                        // и®ҫзҪ®еҹәжң¬еҚ•дҪҚй»ҳи®ӨеҖ?                        document.getElementById('base_unit').value = 'дё?;
                        
                        // жё…з©әеҪ“еүҚдә§е“ҒеҚ•дҪҚ
                        currentProductUnits = [];
                    } else if (mode === 'edit' && productId && productId !== undefined) {
                        // зј–иҫ‘жЁЎејҸ
                        document.getElementById('detail-title').textContent = `дә§е“ҒиҜҰжғ…зј–иҫ‘`;
                        
                        // е…Ҳе°қиҜ•д»Һжң¬ең°ж•°жҚ®дёӯиҺ·еҸ–дә§е“ҒдҝЎжҒ?                        const product = allProducts.find(p => p.productId === productId);
                        
                        if (product) {
                            // еЎ«е……иҜҰжғ…иЎЁеҚ•
                            document.getElementById('detail-sku').textContent = `SKU: ${product.sku}`;
                            document.getElementById('name').value = product.name;
                            document.getElementById('sku').value = product.sku;
                            document.getElementById('price').value = product.price;
                            document.getElementById('base_unit').value = product.base_unit;
                            document.getElementById('supplier_id').value = product.supplierId || '';
                            document.getElementById('warning_stock').value = product.warning_stock;
                            document.getElementById('description').value = product.description;
                            
                            // дҝқеӯҳеҚ•дҪҚжҚўз®—дҝЎжҒҜ
                            currentProductUnits = product.unitConversions || [];
                            
                            // жӣҙж–°еҚ•дҪҚйҖүжӢ©дёӢжӢүжЎ?                            updateUnitSelects();
                            
                            // и®ҫзҪ®й»ҳи®Өе…Ҙеә“еҚ•дҪҚе’Ңй»ҳи®Өй”Җе”®еҚ•дҪ?                            document.getElementById('purchase_unit').value = product.purchase_unit || product.base_unit;
                            document.getElementById('sales_unit').value = product.sales_unit || product.base_unit;
                        } else {
                            // еҸ‘иө·дә§е“ҒиҜҰжғ…иҜ·жұӮ
                            window.wrappedFetch(`/api/v1/rd/products/${productId}`, {
                                method: 'GET'
                            })
                            .then(response => {
                                if (!response.ok) {
                                    throw new Error('Network response was not ok');
                                }
                                return response.json();
                            })
                            .then(data => {
                                if (data.success) {
                                    const product = data.data;
                                    // еЎ«е……иҜҰжғ…иЎЁеҚ•
                                    document.getElementById('detail-sku').textContent = `SKU: ${product.sku}`;
                                    document.getElementById('name').value = product.name;
                                    document.getElementById('sku').value = product.sku;
                                    document.getElementById('price').value = product.price;
                                    document.getElementById('base_unit').value = product.base_unit;
                                    document.getElementById('supplier_id').value = product.supplierId || '';
                                    document.getElementById('warning_stock').value = product.warning_stock;
                                    document.getElementById('description').value = product.description;
                                    
                                    // дҝқеӯҳеҚ•дҪҚжҚўз®—дҝЎжҒҜ
                                    currentProductUnits = product.unitConversions || [];
                                    
                                    // жӣҙж–°еҚ•дҪҚйҖүжӢ©дёӢжӢүжЎ?                                    updateUnitSelects();
                                    
                                    // и®ҫзҪ®й»ҳи®Өе…Ҙеә“еҚ•дҪҚе’Ңй»ҳи®Өй”Җе”®еҚ•дҪ?                                    document.getElementById('purchase_unit').value = product.purchase_unit || product.base_unit;
                                    document.getElementById('sales_unit').value = product.sales_unit || product.base_unit;
                                }
                            })
                            .catch(error => {
                                console.error('иҜ·жұӮдә§е“ҒиҜҰжғ…еӨұиҙҘ:', error);
                                // еҚідҪҝиҜ·жұӮеӨұиҙҘпјҢжЁЎжҖҒжЎҶд№ҹдҝқжҢҒжҳҫзӨ?                            });
                        }

                        // еҸ‘иө·еҚ•дҪҚжҚўз®—иҜ·жұӮпјҲеҰӮжһңжң¬ең°жІЎжңүж•°жҚ®пјү
                        if (!product) {
                            window.wrappedFetch(`/api/v1/rd/products/${productId}/units`, {
                                method: 'GET'
                            })
                            .then(response => {
                                if (!response.ok) {
                                    throw new Error('Network response was not ok');
                                }
                                return response.json();
                            })
                            .then(data => {
                                if (data.success) {
                                    currentProductUnits = data.data;
                                }
                                // жҡӮеӯҳжҚўз®—и®°еҪ•пјҢзӮ№еҮ»вҖңй…ҚзҪ®еҚ•дҪҚжҚўз®—вҖқж—¶еұ•зӨә
                            })
                            .catch(error => {
                                console.error('иҜ·жұӮеҚ•дҪҚжҚўз®—еӨұиҙҘ:', error);
                            });
                            // еҚідҪҝиҜ·жұӮеӨұиҙҘпјҢжЁЎжҖҒжЎҶд№ҹдҝқжҢҒжҳҫзӨ?                        }
                    } else {
                        // е…¶д»–жғ…еҶө
                        console.log('жІЎжңүжҸҗдҫӣдә§е“ҒIDпјҢжҳҫзӨәз©әзҡ„дә§е“ҒиҜҰжғ…жЁЎжҖҒжЎҶ');
                    }
                    
                    // и®ҫзҪ®еҲқе§ӢжЁЎејҸ
                    setEditMode(isEditMode);
                }
                
                // еҲҮжҚўзј–иҫ‘жЁЎејҸ
                function toggleEditMode() {
                    isEditMode = !isEditMode;
                    setEditMode(isEditMode);
                }
                
                // и®ҫзҪ®зј–иҫ‘жЁЎејҸ
                function setEditMode(editMode) {
                    const formInputs = document.querySelectorAll('.form-input');
                    const editBtn = document.getElementById('editProductBtn');
                    const productActions = document.getElementById('productActions');
                    const configUnitBtn = document.querySelector('button[onclick="openUnitModal()"]');
                    
                    // и®ҫзҪ®иЎЁеҚ•е…ғзҙ зҡ„еҸӘиҜ»зҠ¶жҖ?                    formInputs.forEach(input => {
                        if (editMode) {
                            input.removeAttribute('readonly');
                            input.classList.remove('bg-slate-50', 'cursor-not-allowed');
                            input.classList.add('bg-white');
                        } else {
                            input.setAttribute('readonly', 'readonly');
                            input.classList.add('bg-slate-50', 'cursor-not-allowed');
                            input.classList.remove('bg-white');
                        }
                    });
                    
                    // жҳҫзӨә/йҡҗи—Ҹдҝ®ж”№жҢүй’®
                    if (editMode) {
                        editBtn.classList.add('hidden');
                        productActions.classList.remove('hidden');
                        if (configUnitBtn) configUnitBtn.classList.remove('hidden');
                    } else {
                        editBtn.classList.remove('hidden');
                        productActions.classList.add('hidden');
                        if (configUnitBtn) configUnitBtn.classList.add('hidden');
                    }
                }

                // е…ій—ӯдә§е“ҒиҜҰжғ…
                function closeProductDetail() {
                    document.getElementById('product-detail-modal').classList.add('hidden');
                    currentProductId = null;
                    currentProductUnits = [];
                }

                // жҳҫзӨәйҖҡзҹҘ
                function showNotification(message, type = "success") {
                    // еҲӣе»әйҖҡзҹҘе…ғзҙ 
                    const notification = document.createElement('div');
                    const bgColor = type === "error" ? "bg-risk-high" : "bg-brand-600";
                    notification.className = `fixed top-4 right-4 ${bgColor} text-white px-4 py-2 rounded-lg shadow-lg z-50 fade-in`;
                    notification.textContent = message;
                    
                    // ж·»еҠ еҲ°йЎөйқ?                    document.body.appendChild(notification);
                    
                    // 3з§’еҗҺиҮӘеҠЁз§»йҷӨ
                    setTimeout(() => {
                        notification.classList.add('opacity-0', 'transition-opacity', 'duration-500');
                        setTimeout(() => {
                            document.body.removeChild(notification);
                        }, 500);
                    }, 3000);
                }

                // зЎ®и®ӨеҲ йҷӨдә§е“Ғ
                function confirmDeleteProduct(productId, productName) {
                    currentDeleteProductId = productId;
                    document.getElementById('delete-confirm-message').textContent = `зЎ®е®ҡеҲ йҷӨдә§е“Ғ ${productName} еҗ—пјҹ`;
                    document.getElementById('delete-confirm-modal').classList.remove('hidden');
                }

                // е…ій—ӯеҲ йҷӨзЎ®и®Өеј№зӘ—
                function closeDeleteConfirm() {
                    document.getElementById('delete-confirm-modal').classList.add('hidden');
                    currentDeleteProductId = null;
                }

                // зЎ®и®ӨеҲ йҷӨ
                function confirmDelete() {
                    if (currentDeleteProductId) {
                        // еҸ‘иө·еҲ йҷӨиҜ·жұӮ
                        window.wrappedFetch(`/api/v1/rd/products/${currentDeleteProductId}`, {
                            method: 'DELETE'
                        })
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.json();
                        })
                        .then(data => {
                            if (data.success) {
                                showNotification('еҲ йҷӨжҲҗеҠҹ');
                                closeDeleteConfirm();
                                loadProducts(); // еҲ·ж–°еҲ—иЎЁ
                            } else {
                                showNotification('еҲ йҷӨеӨұиҙҘ: ' + (data.message || 'жңӘзҹҘй”ҷиҜҜ'));
                                closeDeleteConfirm();
                            }
                        })
                        .catch(error => {
                            console.error('еҲ йҷӨдә§е“ҒеӨұиҙҘ:', error);
                            showNotification('еҲ йҷӨеӨұиҙҘ: зҪ‘з»ңй”ҷиҜҜ');
                            closeDeleteConfirm();
                        });
                    }
                }

                // дҝқеӯҳдә§е“Ғ
                async function saveProduct() {
                    try {
                        // йҮҮйӣҶиЎЁеҚ•ж•°жҚ®
                        const productData = {
                            productId: currentProductId,
                            name: document.getElementById('name').value,
                            sku: document.getElementById('sku').value,
                            price: parseFloat(document.getElementById('price').value),
                            stock: 0, // й»ҳи®Өдё?
                            userId: 1, // й»ҳи®Өдё?
                            supplierId: document.getElementById('supplier_id').value ? parseInt(document.getElementById('supplier_id').value) : null,
                            baseUnit: document.getElementById('base_unit').value,
                            purchaseUnit: document.getElementById('purchase_unit').value,
                            salesUnit: document.getElementById('sales_unit').value,
                            category: document.getElementById('category').value,
                            warningStock: parseInt(document.getElementById('warning_stock').value) || 0,
                            description: document.getElementById('description').value
                        };
                        const unitConversions = currentProductUnits;

                        const productWithUnitsDTO = {
                            product: productData,
                            unitConversions: unitConversions
                        };

                        // еҸ‘иө·дҝқеӯҳиҜ·жұӮ
                        const response = await window.wrappedFetch('/api/v1/rd/products/save', {
                            method: 'POST',
                            body: JSON.stringify(productWithUnitsDTO)
                        });
                        
                        // жЈҖжҹҘе“Қеә”зҠ¶жҖҒз Ғ
                        if (response.status === 401) {
                            showNotification("зҷ»еҪ•иҝҮжңҹпјҢиҜ·йҮҚж–°зҷ»еҪ•", "error");
                            // и·іиҪ¬еҲ°зҷ»еҪ•йЎөйқ?                            window.location.href = '../../login.html';
                            return;
                        } else if (response.status === 500) {
                            showNotification("жңҚеҠЎеҷЁй…ҚзҪ®й”ҷиҜ?, "error");
                            return;
                        }
                        
                        const data = await response.json();
                        
                        if(data.success) {
                            showNotification("дҝқеӯҳжҲҗеҠҹ");
                            closeProductDetail(); // д»…еңЁжҲҗеҠҹж—¶е…ій—?                            loadProducts();
                        } else {
                            showNotification(data.message, "error");
                        }
                    } catch (error) {
                        console.error("дҝқеӯҳеӨұиҙҘ", error);
                        showNotification('дҝқеӯҳеӨұиҙҘ: ' + error.message, "error");
                    }
                }

                // е…¶д»–иҫ…еҠ©еҮҪж•°
                function switchTab(tab) {
                    const tabs = {
                        dashboard: '../dashboard/dashboard.html',
                        biz: '../SmartOps/SmartOps.html',
                        crm: '../crm/crm.html',
                        supply: 'product-center.html',
                        supplier: '../supply-chain/supply-chain.html'
                    };

                    if (tabs[tab]) {
                        window.location.href = tabs[tab];
                    }
                }

                function openProductSelectModal() {
                    document.getElementById('product-select-modal').classList.remove('hidden');
                }

                function closeProductSelectModal() {
                    document.getElementById('product-select-modal').classList.add('hidden');
                }

                function requestNewProductAnalysis(productName) {
                    document.getElementById('analysisTargetName').textContent = `з ”и®Ёзӣ®ж Үпј?{productName}`;
                    document.getElementById('product-select-modal').classList.add('hidden');
                    document.getElementById('new-product-report-modal').classList.remove('hidden');
                }

                function closeNewProductReport() {
                    document.getElementById('new-product-report-modal').classList.add('hidden');
                }

                function openUnitModal() {
                    const unitModal = document.getElementById('unit-modal');
                    const unitConversionList = document.getElementById('unitConversionList');
                    
                    // жё…з©әзҺ°жңүеҶ…е®№
                    unitConversionList.innerHTML = '';
                    
                    // еҰӮжһңжІЎжңүеҚ•дҪҚжҚўз®—и®°еҪ•пјҢж·»еҠ дёҖжқЎй»ҳи®Өи®°еҪ?                    if (currentProductUnits.length === 0) {
                        addUnitConversionRow();
                    } else {
                        // жҳҫзӨәзҺ°жңүеҚ•дҪҚжҚўз®—и®°еҪ•
                        currentProductUnits.forEach((unit, index) => {
                            addUnitConversionRow(unit, index);
                        });
                    }
                    
                    unitModal.classList.remove('hidden');
                }

                function closeUnitModal() {
                    document.getElementById('unit-modal').classList.add('hidden');
                }

                // ж·»еҠ еҚ•дҪҚжҚўз®—иЎ?                function addUnitConversionRow(unitData = null, index = null) {
                    const unitConversionList = document.getElementById('unitConversionList');
                    const rowIndex = index !== null ? index : unitConversionList.children.length;
                    
                    // еҲӣе»әж–°зҡ„еҚ•дҪҚжҚўз®—иЎ?                    const row = document.createElement('div');
                    row.className = 'flex items-center gap-4';
                    row.dataset.index = rowIndex;
                    
                    // и®ҫзҪ®й»ҳи®ӨеҖ?                    const unitName = unitData ? unitData.unitName : '';
                    const ratio = unitData ? unitData.ratio : 1.0;
                    const isDefault = unitData ? unitData.isDefault : false;
                    
                    row.innerHTML = `
                        <div class="flex-1">
                            <label class="text-[9px] font-black text-slate-400 uppercase block mb-1">еҚ•дҪҚеҗҚз§°</label>
                            <input type="text" value="${unitName}" class="form-input text-center font-bold unit-name-input">
                        </div>
                        <div class="pt-4 text-slate-300">=</div>
                        <div class="flex-1">
                            <label class="text-[9px] font-black text-slate-400 uppercase block mb-1">жҚўз®—жҜ”зҺҮ</label>
                            <input type="number" step="0.1" value="${ratio}" class="form-input text-center text-brand-600 font-black ratio-input">
                        </div>
                        <div class="pt-4 flex items-center">
                            <input type="checkbox" ${isDefault ? 'checked' : ''} class="is-default-input h-4 w-4 text-brand-600 border-slate-300 rounded focus:ring-brand-500">
                            <span class="ml-1 text-xs font-bold">й»ҳи®Ө</span>
                        </div>
                        <div class="pt-1">
                            <button onclick="removeUnitConversionRow(${rowIndex})" class="p-2 text-slate-400 hover:text-red-500 transition-colors">
                                <i class="ph ph-trash"></i>
                            </button>
                        </div>
                    `;
                    
                    unitConversionList.appendChild(row);
                }

                // з§»йҷӨеҚ•дҪҚжҚўз®—иЎ?                function removeUnitConversionRow(index) {
                    const unitConversionList = document.getElementById('unitConversionList');
                    const row = document.querySelector(`[data-index="${index}"]`);
                    
                    if (row) {
                        row.remove();
                        
                        // жӣҙж–°еү©дҪҷиЎҢзҡ„зҙўеј•
                        const rows = unitConversionList.children;
                        for (let i = 0; i < rows.length; i++) {
                            rows[i].dataset.index = i;
                            // жӣҙж–°з§»йҷӨжҢүй’®зҡ„зҙўеј?                            const removeBtn = rows[i].querySelector('button');
                            if (removeBtn) {
                                removeBtn.onclick = () => removeUnitConversionRow(i);
                            }
                        }
                    }
                }

                // дҝқеӯҳеҚ•дҪҚжҚўз®—й…ҚзҪ®
                function saveUnitConversions() {
                    const unitConversionList = document.getElementById('unitConversionList');
                    const rows = unitConversionList.children;
                    const unitConversions = [];
                    
                    // йҮҮйӣҶжүҖжңүеҚ•дҪҚжҚўз®—и®°еҪ?                    for (let i = 0; i < rows.length; i++) {
                        const row = rows[i];
                        const unitNameInput = row.querySelector('.unit-name-input');
                        const ratioInput = row.querySelector('.ratio-input');
                        const isDefaultInput = row.querySelector('.is-default-input');
                        
                        if (unitNameInput && ratioInput && isDefaultInput) {
                            const unitName = unitNameInput.value.trim();
                            const ratio = parseFloat(ratioInput.value);
                            const isDefault = isDefaultInput.checked;
                            
                            if (unitName) {
                                unitConversions.push({
                                    unitName: unitName,
                                    ratio: ratio,
                                    isDefault: isDefault
                                });
                            }
                        }
                    }
                    
                    // жӣҙж–°еҪ“еүҚдә§е“ҒеҚ•дҪҚ
                    currentProductUnits = unitConversions;
                    
                    // е…ій—ӯеј№зӘ—
                    closeUnitModal();
                    
                    // жҳҫзӨәдҝқеӯҳжҲҗеҠҹжҸҗзӨә
                    showNotification('еҚ•дҪҚжҚўз®—е·Ідҝқеӯ?);
                    
                    // жӣҙж–°й»ҳи®Өе…Ҙеә“еҚ•дҪҚе’Ңй»ҳи®Өй”Җе”®еҚ•дҪҚзҡ„дёӢжӢүжЎ?                    updateUnitSelects();
                }
                
                // жӣҙж–°еҚ•дҪҚйҖүжӢ©дёӢжӢүжЎ?                function updateUnitSelects() {
                    const baseUnit = document.getElementById('base_unit').value;
                    const purchaseUnitSelect = document.getElementById('purchase_unit');
                    const salesUnitSelect = document.getElementById('sales_unit');
                    
                    // дҝқеӯҳеҪ“еүҚйҖүдёӯзҡ„еҖ?                    const currentPurchaseUnit = purchaseUnitSelect.value;
                    const currentSalesUnit = salesUnitSelect.value;
                    
                    // жё…з©әзҺ°жңүйҖүйЎ№
                    purchaseUnitSelect.innerHTML = '';
                    salesUnitSelect.innerHTML = '';
                    
                    // ж·»еҠ еҹәжң¬еҚ•дҪҚйҖүйЎ№
                    const baseOption = document.createElement('option');
                    baseOption.value = baseUnit;
                    baseOption.textContent = `${baseUnit} (еҹәжң¬еҚ•дҪҚ)`;
                    purchaseUnitSelect.appendChild(baseOption.cloneNode(true));
                    salesUnitSelect.appendChild(baseOption);
                    
                    // ж·»еҠ иҮӘе®ҡд№үеҚ•дҪҚйҖүйЎ№
                    currentProductUnits.forEach(unit => {
                        const option = document.createElement('option');
                        option.value = unit.unitName;
                        option.textContent = `${unit.unitName} (1${unit.unitName}=${unit.ratio}${baseUnit})`;
                        purchaseUnitSelect.appendChild(option.cloneNode(true));
                        salesUnitSelect.appendChild(option);
                    });
                    
                    // жҒўеӨҚйҖүдёӯзҡ„еҖ?                    if (currentPurchaseUnit) {
                        // жЈҖжҹҘйҖүйЎ№жҳҜеҗҰеӯҳеңЁпјҢеҰӮжһңдёҚеӯҳеңЁеҲҷдҪҝз”Ёеҹәжң¬еҚ•дҪ?                        let optionExists = false;
                        for (let i = 0; i < purchaseUnitSelect.options.length; i++) {
                            if (purchaseUnitSelect.options[i].value === currentPurchaseUnit) {
                                optionExists = true;
                                break;
                            }
                        }
                        if (optionExists) {
                            purchaseUnitSelect.value = currentPurchaseUnit;
                        } else {
                            purchaseUnitSelect.value = baseUnit;
                        }
                    }
                    if (currentSalesUnit) {
                        // жЈҖжҹҘйҖүйЎ№жҳҜеҗҰеӯҳеңЁпјҢеҰӮжһңдёҚеӯҳеңЁеҲҷдҪҝз”Ёеҹәжң¬еҚ•дҪ?                        let optionExists = false;
                        for (let i = 0; i < salesUnitSelect.options.length; i++) {
                            if (salesUnitSelect.options[i].value === currentSalesUnit) {
                                optionExists = true;
                                break;
                            }
                        }
                        if (optionExists) {
                            salesUnitSelect.value = currentSalesUnit;
                        } else {
                            salesUnitSelect.value = baseUnit;
                        }
                    }
                }

                // ================= е…¬е…ұеҮҪж•° =================
                
                /**
                 * еӨ„зҗҶAPIе“Қеә”
                 * @param {Response} response - APIе“Қеә”еҜ№иұЎ
                 * @returns {Promise<Object>} и§ЈжһҗеҗҺзҡ„е“Қеә”ж•°жҚ®
                 */
                async function handleApiResponse(response) {
                    // жЈҖжҹҘе“Қеә”зҠ¶жҖҒз Ғ
                    if (response.status === 401) {
                        showNotification("зҷ»еҪ•иҝҮжңҹпјҢиҜ·йҮҚж–°зҷ»еҪ•", "error");
                        // и·іиҪ¬еҲ°зҷ»еҪ•йЎөйқ?                        window.location.href = '../../login.html';
                        return null;
                    } else if (response.status === 500) {
                        showNotification("жңҚеҠЎеҷЁй…ҚзҪ®й”ҷиҜ?, "error");
                        return null;
                    }

                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const data = await response.json();
                    if (!data.success) {
                        throw new Error(data.message || 'ж“ҚдҪңеӨұиҙҘ');
                    }

                    return data;
                }

                // ================= й«ҳзә§й…ҚзҪ®зӣёе…і =================
                
                /**
                 * еҲҮжҚўй«ҳзә§й…ҚзҪ®жҠҪеұү
                 * @param {string} type - жҠҪеұүзұ»еһӢ
                 */
                function toggleAdvanced(type) {
                    const drawer = document.getElementById(`drawer-${type}`);
                    const icon = document.getElementById(`icon-${type}`);
                    
                    if (drawer.classList.contains('open')) {
                        drawer.classList.remove('open');
                        icon.classList.remove('ph-caret-up');
                        icon.classList.add('ph-caret-down');
                    } else {
                        drawer.classList.add('open');
                        icon.classList.remove('ph-caret-down');
                        icon.classList.add('ph-caret-up');
                    }
                }

                // ================= д»“еә“з®ЎзҗҶзӣёе…і =================
                
                /**
                 * жү“ејҖд»“еә“з®ЎзҗҶжҠҪеұү
                 */
                function openWarehouseDrawer() {
                    document.getElementById('warehouse-drawer').classList.remove('hidden');
                    loadWarehouses();
                }

                /**
                 * е…ій—ӯд»“еә“з®ЎзҗҶжҠҪеұү
                 */
                function closeWarehouseDrawer() {
                    document.getElementById('warehouse-drawer').classList.add('hidden');
                }

                /**
                 * еҠ иҪҪд»“еә“еҲ—иЎЁ
                 */
                async function loadWarehouses() {
                    try {
                        // жЈҖжҹҘи®ӨиҜҒзҠ¶жҖ?                        if (!window.checkAuth()) {
                            return;
                        }

                        // и°ғз”ЁеҗҺз«ҜжҺҘеҸЈиҺ·еҸ–д»“еә“еҲ—иЎЁ
                        const response = await window.wrappedFetch('/api/v1/warehouses', {
                            method: 'GET'
                        });

                        const data = await handleApiResponse(response);
                        if (!data) return;

                        const warehouses = data.data;
                        const warehouseList = document.getElementById('warehouse-list');
                        warehouseList.innerHTML = '';

                        if (!warehouses || warehouses.length === 0) {
                            warehouseList.innerHTML = `
                                <div class="text-center py-8">
                                    <i class="ph ph-building text-4xl text-slate-400 mb-4"></i>
                                    <p class="text-sm font-bold text-slate-400">жҡӮж— д»“еә“</p>
                                    <p class="text-xs text-slate-300 mt-2">иҜ·ж·»еҠ ж–°д»“еә“</p>
                                </div>
                            `;
                            return;
                        }

                        warehouses.forEach(warehouse => {
                            const warehouseItem = document.createElement('div');
                            warehouseItem.className = 'bg-slate-50 rounded-xl p-4';
                            warehouseItem.innerHTML = `
                                <div class="flex justify-between items-start">
                                    <div>
                                        <p class="font-bold text-slate-800">${warehouse.name}</p>
                                        <p class="text-[10px] text-slate-400 mt-0.5">${warehouse.location}</p>
                                    </div>
                                    <div class="flex gap-2">
                                        <button onclick="editWarehouse(${warehouse.warehouseId})" class="p-1.5 hover:bg-slate-100 rounded-full transition-colors">
                                            <i class="ph ph-pencil text-slate-400"></i>
                                        </button>
                                        <button onclick="confirmDeleteWarehouse(${warehouse.warehouseId}, '${warehouse.name}')" class="p-1.5 hover:bg-slate-100 rounded-full transition-colors">
                                            <i class="ph ph-trash text-slate-400"></i>
                                        </button>
                                    </div>
                                </div>
                            `;
                            warehouseList.appendChild(warehouseItem);
                        });
                    } catch (error) {
                        console.error('еҠ иҪҪд»“еә“еҲ—иЎЁејӮеёё:', error);
                        showNotification('еҠ иҪҪд»“еә“еҲ—иЎЁеӨұиҙҘ: ' + error.message);
                    }
                }

                /**
                 * дҝқеӯҳд»“еә“
                 */
                async function saveWarehouse() {
                    const name = document.getElementById('new-warehouse-name').value.trim();
                    const location = document.getElementById('new-warehouse-location').value.trim();

                    if (!name) {
                        showNotification('иҜ·иҫ“е…Ҙд»“еә“еҗҚз§?, 'error');
                        return;
                    }

                    try {
                        // и°ғз”ЁеҗҺз«ҜжҺҘеҸЈдҝқеӯҳд»“еә“
                        const response = await window.wrappedFetch('/api/v1/warehouses', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ name, location })
                        });

                        const data = await handleApiResponse(response);
                        if (!data) return;

                        showNotification('д»“еә“дҝқеӯҳжҲҗеҠҹ', 'success');
                        document.getElementById('new-warehouse-name').value = '';
                        document.getElementById('new-warehouse-location').value = '';
                        loadWarehouses();
                    } catch (error) {
                        console.error('дҝқеӯҳд»“еә“еӨұиҙҘ:', error);
                        showNotification('дҝқеӯҳд»“еә“еӨұиҙҘ: ' + error.message, 'error');
                    }
                }

                /**
                 * зј–иҫ‘д»“еә“
                 * @param {number} warehouseId - д»“еә“ID
                 */
                function editWarehouse(warehouseId) {
                    // иҝҷйҮҢеҸҜд»Ҙж·»еҠ зј–иҫ‘д»“еә“зҡ„йҖ»иҫ‘
                    showNotification('зј–иҫ‘д»“еә“еҠҹиғҪејҖеҸ‘дёӯ', 'info');
                }

                /**
                 * зЎ®и®ӨеҲ йҷӨд»“еә“
                 * @param {number} warehouseId - д»“еә“ID
                 * @param {string} warehouseName - д»“еә“еҗҚз§°
                 */
                function confirmDeleteWarehouse(warehouseId, warehouseName) {
                    currentDeleteWarehouseId = warehouseId;
                    document.getElementById('delete-confirm-message').textContent = `зЎ®е®ҡеҲ йҷӨд»“еә“ ${warehouseName} еҗ—пјҹ`;
                    document.getElementById('delete-confirm-modal').classList.remove('hidden');
                    document.getElementById('delete-confirm-action').onclick = function() {
                        deleteWarehouse(warehouseId);
                    };
                }

                /**
                 * еҲ йҷӨд»“еә“
                 * @param {number} warehouseId - д»“еә“ID
                 */
                async function deleteWarehouse(warehouseId) {
                    try {
                        // и°ғз”ЁеҗҺз«ҜжҺҘеҸЈеҲ йҷӨд»“еә“
                        const response = await window.wrappedFetch(`/api/v1/warehouses/${warehouseId}`, {
                            method: 'DELETE'
                        });

                        const data = await handleApiResponse(response);
                        if (!data) return;

                        showNotification('д»“еә“еҲ йҷӨжҲҗеҠҹ', 'success');
                        closeDeleteConfirm();
                        loadWarehouses();
                    } catch (error) {
                        console.error('еҲ йҷӨд»“еә“еӨұиҙҘ:', error);
                        showNotification('еҲ йҷӨд»“еә“еӨұиҙҘ: ' + error.message, 'error');
                    }
                }

                // ================= иҝӣиҙ§е»әи®®зӣёе…і =================
                
                /**
                 * жү“ејҖиҝӣиҙ§е»әи®®еј№зӘ—
                 */
                async function openPurchaseSuggestionModal() {
                    try {
                        // жЈҖжҹҘи®ӨиҜҒзҠ¶жҖ?                        if (!window.checkAuth()) {
                            return;
                        }

                        // и°ғз”ЁеҗҺз«ҜжҺҘеҸЈиҺ·еҸ–е…ЁйҮҸдә§е“Ғ
                        const response = await window.wrappedFetch('/api/v1/rd/products', {
                            method: 'GET'
                        });

                        const data = await handleApiResponse(response);
                        if (!data) return;

                        const allProducts = data.data;
                        // зӯӣйҖүеҮәеә“еӯҳдҪҺдәҺйў„иӯҰеҖјзҡ„дә§е“Ғ
                        const suggestions = allProducts.filter(p => p.stock <= (p.warning_stock || 0));
                        
                        // жҢүдҫӣеә”е•ҶеҲҶз»„
                        const groupedBySupplier = suggestions.reduce((acc, p) => {
                            const key = p.supplierName || 'жңӘзҹҘдҫӣеә”е•?;
                            if (!acc[key]) acc[key] = [];
                            acc[key].push({
                                id: p.productId,
                                name: p.name,
                                sku: p.sku,
                                current: p.stock,
                                warning: p.warning_stock,
                                suggest: Math.max(0, p.warning_stock * 1.5 - p.stock),
                                price: p.price
                            });
                            return acc;
                        }, {});

                        renderPurchaseModal(groupedBySupplier);
                        document.getElementById('purchase-suggestion-modal').classList.remove('hidden');
                    } catch (error) {
                        console.error('иҺ·еҸ–дә§е“ҒеҲ—иЎЁејӮеёё:', error);
                        showNotification('иҺ·еҸ–дә§е“ҒеҲ—иЎЁеӨұиҙҘ: ' + error.message);
                    }
                }

                /**
                 * жёІжҹ“иҝӣиҙ§е»әи®®еј№зӘ—
                 * @param {Object} groupedBySupplier - жҢүдҫӣеә”е•ҶеҲҶз»„зҡ„иҝӣиҙ§е»әи®?                 */
                function renderPurchaseModal(groupedBySupplier) {
                    const content = document.getElementById('purchase-suggestion-content');
                    content.innerHTML = '';

                    const suppliers = Object.keys(groupedBySupplier);

                    if (suppliers.length === 0) {
                        content.innerHTML = `
                            <div class="text-center py-12">
                                <i class="ph ph-check-circle text-4xl text-brand-500 mb-4"></i>
                                <p class="text-sm font-bold text-slate-700">жҡӮж— иҝӣиҙ§е»әи®®</p>
                                <p class="text-xs text-slate-400 mt-2">жүҖжңүдә§е“Ғеә“еӯҳе……и¶?/p>
                            </div>
                        `;
                        return;
                    }

                    suppliers.forEach(supplierName => {
                        const products = groupedBySupplier[supplierName];
                        const supplierTotal = products.reduce((total, product) => total + (product.suggest * product.price), 0);

                        const supplierSection = document.createElement('div');
                        supplierSection.className = 'bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden';

                        supplierSection.innerHTML = `
                            <div class="px-6 py-4 bg-slate-50/50 border-b border-slate-100 flex justify-between items-center">
                                <h3 class="text-sm font-bold text-slate-800">${supplierName}</h3>
                                <span class="text-xs font-bold text-brand-600">дҫӣеә”е•ҶжҖ»и®Ўпј?${supplierTotal.toFixed(2)}</span>
                            </div>
                            <div class="p-4">
                                <table class="w-full text-left border-collapse">
                                    <thead class="bg-slate-50/50 text-[10px] text-slate-400 font-black uppercase tracking-tighter border-b border-slate-100">
                                        <tr>
                                            <th class="px-4 py-3">дә§е“Ғеҗ?(SKU)</th>
                                            <th class="px-4 py-3 text-right">зјәиҙ§зҠ¶жҖ?/th>
                                            <th class="px-4 py-3 text-right">е»әи®®йҮҮиҙӯ</th>
                                            <th class="px-4 py-3 text-right">йў„дј°е°Ҹи®Ў</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-xs divide-y divide-slate-50">
                                        ${products.map(product => {
                                            const subtotal = product.suggest * product.price;
                                            return `
                                                <tr>
                                                    <td class="px-4 py-3">
                                                        <p class="font-bold text-slate-800">${product.name}</p>
                                                        <p class="text-[10px] text-slate-400 font-mono uppercase">SKU: ${product.sku}</p>
                                                    </td>
                                                    <td class="px-4 py-3 text-right font-mono font-bold text-risk-high">
                                                        ${product.current} / ${product.warning}
                                                    </td>
                                                    <td class="px-4 py-3 text-right">
                                                        <div class="flex items-center justify-end gap-2">
                                                            <button onclick="decreaseQuantity(this)" class="p-1 hover:bg-slate-100 rounded-full transition-colors">
                                                                <i class="ph ph-minus text-slate-400"></i>
                                                            </button>
                                                            <input type="number" value="${product.suggest}" min="0" class="w-16 px-2 py-1 border border-slate-200 rounded-lg text-xs text-center" onchange="updateSubtotal(this)">
                                                            <button onclick="increaseQuantity(this)" class="p-1 hover:bg-slate-100 rounded-full transition-colors">
                                                                <i class="ph ph-plus text-slate-400"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                    <td class="px-4 py-3 text-right font-mono font-bold text-brand-600 subtotal">
                                                        $${subtotal.toFixed(2)}
                                                    </td>
                                                </tr>
                                            `;
                                        }).join('')}
                                    </tbody>
                                </table>
                            </div>
                        `;

                        content.appendChild(supplierSection);
                    });
                }

                /**
                 * еҮҸе°‘йҮҮиҙӯж•°йҮҸ
                 * @param {HTMLElement} button - еҮҸе°‘жҢүй’®
                 */
                function decreaseQuantity(button) {
                    const input = button.nextElementSibling;
                    if (parseInt(input.value) > 0) {
                        input.value = parseInt(input.value) - 1;
                        updateSubtotal(input);
                    }
                }

                /**
                 * еўһеҠ йҮҮиҙӯж•°йҮҸ
                 * @param {HTMLElement} button - еўһеҠ жҢүй’®
                 */
                function increaseQuantity(button) {
                    const input = button.previousElementSibling;
                    input.value = parseInt(input.value) + 1;
                    updateSubtotal(input);
                }

                /**
                 * жӣҙж–°е°Ҹи®ЎйҮ‘йўқ
                 * @param {HTMLElement} input - ж•°йҮҸиҫ“е…ҘжЎ?                 */
                function updateSubtotal(input) {
                    const row = input.closest('tr');
                    const price = parseFloat(row.querySelector('.subtotal').textContent.replace('$', ''));
                    const quantity = parseInt(input.value);
                    const subtotal = quantity * price;
                    row.querySelector('.subtotal').textContent = `$${subtotal.toFixed(2)}`;
                }

                /**
                 * е…ій—ӯиҝӣиҙ§е»әи®®еј№зӘ—
                 */
                function closePurchaseSuggestionModal() {
                    document.getElementById('purchase-suggestion-modal').classList.add('hidden');
                }

                /**
                 * дҝқеӯҳиҝӣиҙ§еҚ?                 */
                function savePurchaseOrder() {
                    // иҝҷйҮҢеҸҜд»Ҙж·»еҠ дҝқеӯҳиҝӣиҙ§еҚ•зҡ„йҖ»иҫ‘
                    showNotification('иҝӣиҙ§еҚ•дҝқеӯҳеҠҹиғҪејҖеҸ‘дёӯ', 'info');
                }
            </script>

    <!-- [дәҢзә§еј№зӘ—] еҚ•дҪҚжҚўз®— -->
